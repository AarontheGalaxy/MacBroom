# ── Scan (parallel) ────────────────────────────────────────────
_run_scan() {
    mb_disk_clear_cache
    local total="${#MB_MOD_NAMES[@]}"
    local tmpdir
    tmpdir=$(mktemp -d)
    local progress_dir="$tmpdir/progress"
    mkdir -p "$progress_dir"

    local i
    for (( i=0; i<total; i++ )); do
        local fn="${MB_MOD_SCAN_FNS[$i]}"
        local name="${MB_MOD_NAMES[$i]}"
        local label="${MB_MOD_LABELS[$i]}"
        # Dependency check
        local req_fn="${name}_requires"
        if declare -f "$req_fn" &>/dev/null; then
            local req_cmd; req_cmd=$("$req_fn")
            if ! command -v "$req_cmd" &>/dev/null; then
                ( printf '0' > "$tmpdir/$i" )
                continue
            fi
        fi
        # Skip deferred modules at startup — their scan runs lazily when opened
        if [[ "${MB_MOD_DEFERRED[$i]:-0}" -eq 1 ]]; then
            printf '0' > "$tmpdir/$i"
            continue
        fi
        # Run scan. Create a progress file while running.
        (
            touch "$progress_dir/$i"
            "$fn" > "$tmpdir/$i" 2>/dev/null
            rm -f "$progress_dir/$i"
        ) < /dev/null &
    done
    
    # Wait for all scans while updating TUI with active modules
    while true; do
        local active_count
        active_count=$(ls "$progress_dir" 2>/dev/null | wc -l)
        if [[ "$active_count" -eq 0 ]]; then break; fi

        if [[ "${MB_TUI_STATE:-}" == "SCANNING" ]]; then
            local first_active_idx
            first_active_idx=$(ls "$progress_dir" 2>/dev/null | head -1)
            if [[ -n "$first_active_idx" ]]; then
                mb_tui_render "${MB_MOD_LABELS[$first_active_idx]:-Scanning...}"
            fi
        fi
        sleep 0.2
    done
    wait

    MB_MOD_SIZES_KB=()
    for (( i=0; i<total; i++ )); do
        local s=0
        [[ -f "$tmpdir/$i" ]] && s=$(cat "$tmpdir/$i")
        [[ "$s" =~ ^[0-9]+$ ]] || s=0
        MB_MOD_SIZES_KB+=("$s")
    done

    rm -rf "$tmpdir"

    MB_DISK_USED_KB=$(mb_disk_used_kb)
    MB_DISK_TOTAL_KB=$(mb_disk_total_kb)
}

# ── Clean engine ───────────────────────────────────────────────
_run_clean_modules() {
    local dry_run="${1:-false}"
    MB_CLEAN_TOTAL=0

    if [[ "$dry_run" != "true" ]]; then
        mb_undo_session_start
    fi

    local i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        MB_CLEAN_FREED[$i]=0
        if [[ "${MB_MOD_SELECTED[$i]:-0}" -eq 1 ]]; then
            MB_CLEAN_STATUS[$i]="waiting"
        else
            MB_CLEAN_STATUS[$i]="skipped"
        fi
    done

    # Draw initial cleaning screen once
    MB_TUI_STATE="CLEANING"
    mb_tui_render

    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        [[ "${MB_MOD_SELECTED[$i]:-0}" -eq 1 ]] || continue

        MB_CLEAN_STATUS[$i]="cleaning"
        mb_tui_render  # full redraw to show "cleaning..." for this module

        local fn="${MB_MOD_CLEAN_FNS[$i]}"
        export MB_CURRENT_MODULE="${MB_MOD_NAMES[$i]}"
        local rfile
        rfile=$(mktemp)

        # Compute the rendered row: row 4 = first drawn module (skipped ones don't appear)
        local mod_row=4
        local _j
        for (( _j=0; _j<i; _j++ )); do
            [[ "${MB_CLEAN_STATUS[$_j]:-}" != "skipped" ]] && mod_row=$(( mod_row + 1 ))
        done

        "$fn" "$dry_run" "$rfile" >/dev/null 2>&1 &
        local cpid=$!
        (
            local cyc=0
            local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
            while true; do
                local frame="${frames:$cyc:1}"
                mb_goto 4 "$mod_row"
                printf '%s%s%s' "${C_CYAN}" "$frame" "${C_NC}"
                cyc=$(( (cyc + 1) % 10 ))
                sleep 0.12
            done
        ) &
        local spin_pid=$!

        wait "$cpid" 2>/dev/null || true
        kill "$spin_pid" 2>/dev/null || true
        wait "$spin_pid" 2>/dev/null || true

        local freed=0
        if [[ -f "$rfile" ]]; then freed=$(cat "$rfile"); fi
        [[ "$freed" =~ ^[0-9]+$ ]] || freed=0
        rm -f "$rfile"

        MB_CLEAN_FREED[$i]=$freed
        MB_CLEAN_STATUS[$i]="done"
        MB_CLEAN_TOTAL=$(( MB_CLEAN_TOTAL + freed ))
        mb_tui_render  # redraw to show "done ✓" for this module
    done

    if [[ "$dry_run" != "true" ]]; then
        mb_undo_session_end
    fi
}

# ── JSON backend ───────────────────────────────────────────────
_json_scan() {
    _run_scan
    printf '{\n  "disk": {'
    printf '"used_kb": %d, "total_kb": %d, "free_kb": %d},\n' \
        "$MB_DISK_USED_KB" "$MB_DISK_TOTAL_KB" \
        "$(mb_disk_free_kb)"
    printf '  "modules": [\n'
    local i total="${#MB_MOD_NAMES[@]}"
    for (( i=0; i<total; i++ )); do
        printf '    {"id": "%s", "label": "%s", "size_kb": %d}' \
            "${MB_MOD_NAMES[$i]}" "${MB_MOD_LABELS[$i]}" "${MB_MOD_SIZES_KB[$i]:-0}"
        (( i < total-1 )) && printf ','
        printf '\n'
    done
    printf '  ]\n}\n'
}

_json_list() {
    local mod="$1"
    local fn="" label="" idx=0 i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        if [[ "${MB_MOD_NAMES[$i]}" == "$mod" ]]; then
            fn="${MB_MOD_LIST_FNS[$i]}"
            label="${MB_MOD_LABELS[$i]}"
            idx=$i
            break
        fi
    done
    [[ -z "$fn" ]] && { printf '{"error": "unknown module: %s"}\n' "$mod"; return 1; }

    printf '{"module": "%s", "label": "%s", "items": [\n' "$mod" "$label"
    local first=true
    local line sk rest slabel
    while IFS= read -r line; do
        sk="${line%%|*}"
        rest="${line#*|}"
        slabel="${rest%%|*}"
        [[ "$first" == "true" ]] && first=false || printf ',\n'
        printf '  {"label": "%s", "size_kb": %d}' "$slabel" "$sk"
    done < <("$fn" 2>/dev/null)
    printf '\n]}\n'
}

# ── Preview: clean only selected items ────────────────────────
_run_clean_preview_selected() {
    local dry_run="${MB_DRY_RUN:-false}"
    local i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        MB_CLEAN_FREED[$i]=0
        if [[ "${MB_MOD_NAMES[$i]}" == "$MB_PREVIEW_MOD" ]]; then
            MB_MOD_SELECTED[$i]=1
            MB_CLEAN_STATUS[$i]="cleaning"
        else
            MB_MOD_SELECTED[$i]=0
            MB_CLEAN_STATUS[$i]="skipped"
        fi
    done
    MB_CLEAN_TOTAL=0
    MB_TUI_STATE="CLEANING"
    mb_tui_render

    export MB_CURRENT_MODULE="$MB_PREVIEW_MOD"
    [[ "$dry_run" != "true" ]] && mb_undo_session_start
    local freed=0
    for (( i=0; i<${#MB_PREVIEW_ITEMS[@]}; i++ )); do
        [[ "${MB_PREVIEW_SELECTED[$i]:-0}" -eq 1 ]] || continue
        local item="${MB_PREVIEW_ITEMS[$i]}"
        local spath="${item##*|}"
        local s
        s=$(mb_size_kb "$spath")
        if [[ "$dry_run" == "true" ]]; then
            freed=$(( freed + s ))
        else
            if mb_safe_rm "$spath"; then
                freed=$(( freed + s ))
            fi
        fi
    done
    [[ "$dry_run" != "true" ]] && mb_undo_session_end

    local mod_idx=0
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        if [[ "${MB_MOD_NAMES[$i]}" == "$MB_PREVIEW_MOD" ]]; then mod_idx=$i; break; fi
    done
    MB_CLEAN_FREED[$mod_idx]=$freed
    MB_CLEAN_STATUS[$mod_idx]="done"
    MB_CLEAN_TOTAL=$freed
}

# ── Preview loader ─────────────────────────────────────────────
_load_preview() {
    local mod="$1"
    MB_PREVIEW_LOADING=true
    MB_PREVIEW_ITEMS=()
    MB_PREVIEW_SELECTED=()
    MB_PREVIEW_CURSOR=0
    MB_PREVIEW_SCROLL=0
    MB_PREVIEW_FILTER=""
    MB_PREVIEW_FILTER_MODE=false
    MB_PREVIEW_DRILL_STACK=()
    MB_PREVIEW_DRILL_DEPTH=0
    mb_tui_render

    local fn="" i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        if [[ "${MB_MOD_NAMES[$i]}" == "$mod" ]]; then fn="${MB_MOD_LIST_FNS[$i]}"; break; fi
    done

    local tmpfile
    tmpfile=$(mktemp)
    ( "$fn" > "$tmpfile" 2>/dev/null ) &
    local lpid=$!

    while kill -0 "$lpid" 2>/dev/null; do
        mb_tui_render  # animate spinner
        sleep 0.1
    done
    wait "$lpid" 2>/dev/null || true

    MB_PREVIEW_ITEMS=()
    local line
    while IFS= read -r line; do
        [[ -n "$line" ]] && MB_PREVIEW_ITEMS+=("$line")
    done < "$tmpfile"
    rm -f "$tmpfile"

    # Find the module index once — used for pre-selection and deferred size update.
    local _pidx=0 _pi
    for (( _pi=0; _pi<${#MB_MOD_NAMES[@]}; _pi++ )); do
        [[ "${MB_MOD_NAMES[$_pi]}" == "$mod" ]] && { _pidx=$_pi; break; }
    done

    # If this module is already selected on the main screen (●), pre-select all items.
    if [[ "${MB_MOD_SELECTED[$_pidx]:-0}" -eq 1 ]]; then
        for (( _pi=0; _pi<${#MB_PREVIEW_ITEMS[@]}; _pi++ )); do
            MB_PREVIEW_SELECTED[$_pi]=1
        done
    fi

    # For deferred modules, sum item sizes now so the main screen shows the real
    # size (instead of —) when the user returns from Preview.
    if [[ "${MB_MOD_DEFERRED[$_pidx]:-0}" -eq 1 ]]; then
        local _deferred_total=0 _item_sz
        for (( _pi=0; _pi<${#MB_PREVIEW_ITEMS[@]}; _pi++ )); do
            _item_sz=$(printf '%s' "${MB_PREVIEW_ITEMS[$_pi]}" | cut -d'|' -f1)
            [[ "$_item_sz" =~ ^[0-9]+$ ]] && _deferred_total=$(( _deferred_total + _item_sz ))
        done
        MB_MOD_SIZES_KB[$_pidx]=$_deferred_total
    fi

    MB_PREVIEW_LOADING=false
}

# ── TUI main loop ──────────────────────────────────────────────
_tui_main() {
    # Arithmetic conditions like (( x > 0 )) exit with status 1 when false,
    # which would abort the loop under set -e. Disable only exit-on-error;
    # set -u (unbound variable) stays active to catch typos.
    set +e

    # Init selection and scroll
    local i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        MB_MOD_SELECTED[$i]=0
    done
    MB_SCROLL=0
    MB_CURSOR=0

    MB_TUI_STATE="SCANNING"
    tput smcup  2>/dev/null || true
    tput civis  2>/dev/null || true

    trap 'mb_tui_cleanup; exit 0' INT TERM EXIT
    trap 'mb_tui_on_resize' WINCH

    mb_update_term_size

    # Save terminal settings once; restored by mb_tui_cleanup on exit.
    _MB_STTY_SAVE=$(stty -g 2>/dev/null) || true

    _run_scan

    # After parallel scan, restore terminal and set raw mode for key reading.
    # Background scan jobs may have altered stty settings even with < /dev/null.
    if [[ -n "$_MB_STTY_SAVE" ]]; then
        stty "$_MB_STTY_SAVE" 2>/dev/null || true
    fi
    stty -echo -icanon min 1 time 0 2>/dev/null || true

    # Cache APFS purgeable info once (avoid running diskutil on every render)
    _MB_APFS_PURGEABLE=$(diskutil apfs list 2>/dev/null | \
        awk '/Purgeable/ {match($0, /[0-9.]+ [KMGT]B/); if (RSTART) print substr($0, RSTART, RLENGTH)}' | \
        head -1 2>/dev/null) || true
    export _MB_APFS_PURGEABLE

    MB_TUI_STATE="MAIN"

    # ── Main event loop ────────────────────────────────────────
    while true; do
        mb_tui_render
        mb_read_key
        local key="$MB_LAST_KEY"

        if [[ "$key" == "EOF" ]]; then
            # If we get EOF, we are likely in a non-interactive shell.
            # Sleep to prevent a tight CPU loop.
            sleep 1
            continue
        fi

        case "$MB_TUI_STATE" in

            # ── MAIN screen ──────────────────────────────────
            MAIN)
                local total="${#MB_MOD_NAMES[@]}"
                case "$key" in
                    $'\x1b[A'|$'\x1bOA'|k|K)   # Up
                        if (( MB_CURSOR > 0 )); then
                            MB_CURSOR=$(( MB_CURSOR - 1 ))
                        fi
                        if (( MB_CURSOR < MB_SCROLL )); then
                            MB_SCROLL=$MB_CURSOR
                        fi
                        ;;
                    $'\x1b[B'|$'\x1bOB'|j|J)   # Down
                        if (( MB_CURSOR < total - 1 )); then
                            MB_CURSOR=$(( MB_CURSOR + 1 ))
                        fi
                        local _vis=$(( _MB_LIST_ROWS > 0 ? _MB_LIST_ROWS : 15 ))
                        if (( MB_CURSOR >= MB_SCROLL + _vis )); then
                            MB_SCROLL=$(( MB_CURSOR - _vis + 1 ))
                        fi
                        ;;
                    ' ')             # Space – toggle
                        if [[ "${MB_MOD_SELECTED[$MB_CURSOR]:-0}" -eq 1 ]]; then
                            MB_MOD_SELECTED[$MB_CURSOR]=0
                        else
                            MB_MOD_SELECTED[$MB_CURSOR]=1
                        fi
                        ;;
                    $'\x1b[C'|$'\x1bOC'|l|L)  # Right arrow – preview
                        MB_PREVIEW_MOD="${MB_MOD_NAMES[$MB_CURSOR]}"
                        MB_TUI_STATE="PREVIEW"
                        _load_preview "$MB_PREVIEW_MOD"
                        ;;
                    a|A)             # Select all — skip risky modules
                        for (( i=0; i<total; i++ )); do
                            [[ "${MB_MOD_SAFETY[$i]:-safe}" == "risky" ]] && continue
                            MB_MOD_SELECTED[$i]=1
                        done
                        ;;
                    n|N)             # Deselect all
                        for (( i=0; i<total; i++ )); do MB_MOD_SELECTED[$i]=0; done
                        ;;
                    w|W)  # Whitelist manager
                        MB_WL_CURSOR=0
                        MB_WL_SCROLL=0
                        MB_WL_INPUT=""
                        MB_WL_INPUT_MODE=false
                        MB_TUI_STATE="WHITELIST"
                        ;;
                    s|S)  # System status
                        MB_TUI_STATE="STATUS"
                        mb_tui_render   # show "loading..." frame first
                        mb_collect_status
                        ;;
                    d|D)  # Dry run toggle
                        if [[ "$MB_DRY_RUN" == "true" ]]; then
                            MB_DRY_RUN=false
                        else
                            MB_DRY_RUN=true
                        fi
                        ;;
                    $'\n'|$'\r')  # Enter – start cleaning
                        local any=0
                        for (( i=0; i<total; i++ )); do
                            if [[ "${MB_MOD_SELECTED[$i]:-0}" -eq 1 ]]; then any=1; break; fi
                        done
                        if [[ "$any" -eq 1 ]]; then
                            MB_TUI_STATE="CLEANING"
                            _run_clean_modules "$MB_DRY_RUN"
                            MB_TUI_STATE="DONE"
                        fi
                        ;;
                    q|Q)
                        trap - INT TERM EXIT WINCH
                        mb_tui_cleanup
                        exit 0
                        ;;
                esac
                ;;

            # ── PREVIEW screen ────────────────────────────────
            PREVIEW)
                local total_items="${#MB_PREVIEW_ITEMS[@]}"
                # Use the list_rows computed by _render_preview so scroll bounds match exactly.
                local vis_rows="${_MB_PREVIEW_LIST_ROWS:-10}"
                if [[ $vis_rows -lt 3 ]]; then vis_rows=3; fi

                # Pre-calculate filtered indices for consistent interaction
                local filtered_indices=()
                local _idx
                for (( _idx=0; _idx<total_items; _idx++ )); do
                    local _item="${MB_PREVIEW_ITEMS[$_idx]}"
                    local _rest="${_item#*|}"
                    local _slabel="${_rest%%|*}"
                    if [[ -z "$MB_PREVIEW_FILTER" ]] || [[ "${_slabel,,}" == *"${MB_PREVIEW_FILTER,,}"* ]]; then
                        filtered_indices+=("$_idx")
                    fi
                done
                local num_filtered="${#filtered_indices[@]}"

                case "$key" in
                    $'\x1b[A'|$'\x1bOA'|k|K)   # Up
                        if (( MB_PREVIEW_CURSOR > 0 )); then
                            MB_PREVIEW_CURSOR=$(( MB_PREVIEW_CURSOR - 1 ))
                        fi
                        if (( MB_PREVIEW_CURSOR < MB_PREVIEW_SCROLL )); then
                            MB_PREVIEW_SCROLL=$MB_PREVIEW_CURSOR
                        fi
                        ;;
                    $'\x1b[B'|$'\x1bOB'|j|J)   # Down
                        if (( MB_PREVIEW_CURSOR < num_filtered - 1 )); then
                            MB_PREVIEW_CURSOR=$(( MB_PREVIEW_CURSOR + 1 ))
                        fi
                        if (( MB_PREVIEW_CURSOR >= MB_PREVIEW_SCROLL + vis_rows )); then
                            MB_PREVIEW_SCROLL=$(( MB_PREVIEW_CURSOR - vis_rows + 1 ))
                        fi
                        ;;
                    ' ')             # Toggle item
                        if [[ "$num_filtered" -gt 0 ]]; then
                            local real_idx="${filtered_indices[$MB_PREVIEW_CURSOR]}"
                            if [[ "${MB_PREVIEW_SELECTED[$real_idx]:-0}" -eq 1 ]]; then
                                MB_PREVIEW_SELECTED[$real_idx]=0
                            else
                                MB_PREVIEW_SELECTED[$real_idx]=1
                            fi
                        fi
                        ;;
                    a|A)             # Select all items
                        for (( i=0; i<num_filtered; i++ )); do 
                            local real_idx="${filtered_indices[$i]}"
                            MB_PREVIEW_SELECTED[$real_idx]=1
                        done
                        ;;
                    n|N)             # Deselect all items
                        for (( i=0; i<num_filtered; i++ )); do 
                            local real_idx="${filtered_indices[$i]}"
                            MB_PREVIEW_SELECTED[$real_idx]=0
                        done
                        ;;
                    $'\x1b[D'|$'\x1bOD'|h|H)  # Left arrow / h — go back
                        if (( MB_PREVIEW_DRILL_DEPTH > 0 )); then
                            # Exit one level of drill-down
                            MB_PREVIEW_DRILL_STACK=("${MB_PREVIEW_DRILL_STACK[@]:0:$(( ${#MB_PREVIEW_DRILL_STACK[@]} - 1 ))}")
                            MB_PREVIEW_DRILL_DEPTH=$(( MB_PREVIEW_DRILL_DEPTH - 1 ))
                            if (( MB_PREVIEW_DRILL_DEPTH == 0 )); then
                                _load_preview "$MB_PREVIEW_MOD"
                            else
                                local _parent="${MB_PREVIEW_DRILL_STACK[-1]}"
                                MB_PREVIEW_ITEMS=()
                                MB_PREVIEW_SELECTED=()
                                MB_PREVIEW_CURSOR=0
                                MB_PREVIEW_SCROLL=0
                                local _ptmp; _ptmp=$(mktemp)
                                (
                                    find "$_parent" -maxdepth 1 -mindepth 1 -print0 2>/dev/null | \
                                    while IFS= read -r -d '' _pi; do
                                        local _ps; _ps=$(du -sk -- "$_pi" 2>/dev/null | awk '{print $1+0; exit}')
                                        printf '%d|%s|%s\n' "${_ps:-0}" "$(basename "$_pi")" "$_pi"
                                    done | sort -t'|' -k1 -rn
                                ) > "$_ptmp" 2>/dev/null
                                while IFS= read -r _pl; do
                                    [[ -n "$_pl" ]] && MB_PREVIEW_ITEMS+=("$_pl")
                                done < "$_ptmp"
                                rm -f "$_ptmp"
                            fi
                        else
                            MB_TUI_STATE="MAIN"
                        fi
                        ;;
                    '/')             # Open search/filter mode
                        MB_PREVIEW_FILTER_MODE=true
                        MB_PREVIEW_FILTER=""
                        MB_PREVIEW_SCROLL=0
                        MB_PREVIEW_CURSOR=0
                        ;;
                    $'\x1b')         # Escape — clear filter or go back
                        if [[ "$MB_PREVIEW_FILTER_MODE" == "true" ]] || [[ -n "$MB_PREVIEW_FILTER" ]]; then
                            MB_PREVIEW_FILTER_MODE=false
                            MB_PREVIEW_FILTER=""
                            MB_PREVIEW_SCROLL=0
                            MB_PREVIEW_CURSOR=0
                        else
                            MB_TUI_STATE="MAIN"
                        fi
                        ;;
                    $'\n'|$'\r')  # Enter
                        # Check for drill-down: is the cursor on an unchecked directory?
                        if [[ "$num_filtered" -gt 0 ]]; then
                            local real_idx="${filtered_indices[$MB_PREVIEW_CURSOR]}"
                            local _cur_item="${MB_PREVIEW_ITEMS[$real_idx]:-}"
                            local _cur_path="${_cur_item##*|}"
                            if [[ -d "$_cur_path" ]] && \
                               [[ "${MB_PREVIEW_SELECTED[$real_idx]:-0}" -eq 0 ]]; then
                                # Drill-down: enter this directory
                                MB_PREVIEW_DRILL_STACK+=("$_cur_path")
                                MB_PREVIEW_DRILL_DEPTH=$(( MB_PREVIEW_DRILL_DEPTH + 1 ))
                                # List the directory contents
                                MB_PREVIEW_LOADING=true
                                MB_PREVIEW_ITEMS=()
                                MB_PREVIEW_SELECTED=()
                                MB_PREVIEW_CURSOR=0
                                MB_PREVIEW_SCROLL=0
                                local _drill_tmp; _drill_tmp=$(mktemp)
                                (
                                    find "$_cur_path" -maxdepth 1 -mindepth 1 -print0 2>/dev/null | \
                                    while IFS= read -r -d '' _di; do
                                        local _ds; _ds=$(du -sk -- "$_di" 2>/dev/null | awk '{print $1+0; exit}')
                                        printf '%d|%s|%s\n' "${_ds:-0}" "$(basename "$_di")" "$_di"
                                    done | sort -t'|' -k1 -rn
                                ) > "$_drill_tmp" 2>/dev/null
                                while IFS= read -r _dl; do
                                    [[ -n "$_dl" ]] && MB_PREVIEW_ITEMS+=("$_dl")
                                done < "$_drill_tmp"
                                rm -f "$_drill_tmp"
                                MB_PREVIEW_LOADING=false
                                continue
                            fi
                        fi
                        local any=0
                        for (( i=0; i<total_items; i++ )); do
                            if [[ "${MB_PREVIEW_SELECTED[$i]:-0}" -eq 1 ]]; then any=1; break; fi
                        done
                        if [[ "$any" -eq 1 ]]; then
                            _run_clean_preview_selected
                            MB_TUI_STATE="DONE"
                        fi
                        ;;
                    *)
                        if [[ "$MB_PREVIEW_FILTER_MODE" == "true" ]]; then
                            if [[ "$key" == $'\x7f' ]] || [[ "$key" == $'\x08' ]]; then
                                # Backspace
                                [[ ${#MB_PREVIEW_FILTER} -gt 0 ]] && \
                                    MB_PREVIEW_FILTER="${MB_PREVIEW_FILTER%?}"
                            elif [[ ${#key} -eq 1 ]] && [[ "$key" =~ [[:print:]] ]]; then
                                MB_PREVIEW_FILTER+="$key"
                            fi
                            MB_PREVIEW_SCROLL=0
                            MB_PREVIEW_CURSOR=0
                        fi
                        ;;
                    q|Q)
                        trap - INT TERM EXIT WINCH
                        mb_tui_cleanup
                        exit 0
                        ;;
                esac
                ;;

            # ── WHITELIST screen ───────────────────────────────
            WHITELIST)
                local wl_n="${#MB_WHITELIST[@]}"
                if [[ "$MB_WL_INPUT_MODE" == "true" ]]; then
                    case "$key" in
                        $'\n'|$'\r')
                            if [[ -n "$MB_WL_INPUT" ]]; then
                                mb_whitelist_add "$MB_WL_INPUT"
                            fi
                            MB_WL_INPUT=""
                            MB_WL_INPUT_MODE=false
                            ;;
                        $'\x1b')
                            MB_WL_INPUT=""
                            MB_WL_INPUT_MODE=false
                            ;;
                        $'\x7f'|$'\x08')
                            [[ ${#MB_WL_INPUT} -gt 0 ]] && MB_WL_INPUT="${MB_WL_INPUT%?}"
                            ;;
                        *)
                            if [[ ${#key} -eq 1 ]] && [[ "$key" =~ [[:print:]] ]]; then
                                MB_WL_INPUT+="$key"
                            fi
                            ;;
                    esac
                else
                    case "$key" in
                        $'\x1b[A'|$'\x1bOA'|k|K)
                            if (( MB_WL_CURSOR > 0 )); then
                                MB_WL_CURSOR=$(( MB_WL_CURSOR - 1 ))
                                if (( MB_WL_CURSOR < MB_WL_SCROLL )); then MB_WL_SCROLL=$MB_WL_CURSOR; fi
                            fi
                            ;;
                        $'\x1b[B'|$'\x1bOB'|j|J)
                            if (( wl_n > 0 && MB_WL_CURSOR < wl_n - 1 )); then
                                MB_WL_CURSOR=$(( MB_WL_CURSOR + 1 ))
                                local _wvis=$(( _MB_ROWS - 9 )); [[ $_wvis -lt 1 ]] && _wvis=1
                                if (( MB_WL_CURSOR >= MB_WL_SCROLL + _wvis )); then
                                    MB_WL_SCROLL=$(( MB_WL_CURSOR - _wvis + 1 ))
                                fi
                            fi
                            ;;
                        a|A)
                            MB_WL_INPUT_MODE=true
                            MB_WL_INPUT=""
                            ;;
                        d|D)
                            if (( wl_n > 0 && MB_WL_CURSOR < wl_n )); then
                                mb_whitelist_remove "${MB_WHITELIST[$MB_WL_CURSOR]}"
                                local new_n="${#MB_WHITELIST[@]}"
                                if (( MB_WL_CURSOR >= new_n && new_n > 0 )); then
                                    MB_WL_CURSOR=$(( new_n - 1 ))
                                fi
                            fi
                            ;;
                        $'\x1b[D'|$'\x1bOD'|h|H|$'\x1b'|q|Q)
                            MB_TUI_STATE="MAIN"
                            ;;
                    esac
                fi
                ;;

            # ── STATUS screen ──────────────────────────────────
            STATUS)
                case "$key" in
                    r|R)
                        mb_collect_status
                        ;;
                    $'\x1b[D'|$'\x1bOD'|h|H|$'\x1b'|q|Q)
                        MB_TUI_STATE="MAIN"
                        ;;
                esac
                ;;

            # ── DONE screen ────────────────────────────────────
            DONE)
                if [[ "$key" == 'q' || "$key" == 'Q' ]]; then
                    trap - INT TERM EXIT WINCH
                    mb_tui_cleanup
                    exit 0
                fi
                MB_TUI_STATE="SCANNING"
                mb_tui_render
                _run_scan
                MB_TUI_STATE="MAIN"
                ;;
        esac
    done
}

# ── CLI: non-interactive scan report ──────────────────────────
_cmd_scan() {
    local use_json=false
    [[ "${1:-}" == "--json" ]] && use_json=true

    if [[ "$use_json" == "true" ]]; then
        _json_scan
        return
    fi

    # Pretty scan report
    local bar_w=20

    if [[ -t 1 ]]; then
        local pid
        (while true; do
            printf "\r  ${C_CYAN}⠋${C_NC}  Scanning..."; sleep 0.1
            printf "\r  ${C_CYAN}⠙${C_NC}  Scanning..."; sleep 0.1
        done) &
        pid=$!
        _run_scan
        kill "$pid" 2>/dev/null || true
        wait "$pid" 2>/dev/null || true
        printf "\r\033[2K"
    else
        _run_scan
    fi

    printf "\n"
    mb_bold "  MacBroom  –  Scan Report"
    printf "\n"

    local disk_pct=0
    if (( MB_DISK_TOTAL_KB > 0 )); then
        disk_pct=$(( MB_DISK_USED_KB * 100 / MB_DISK_TOTAL_KB ))
    fi
    local disk_bar; disk_bar=$(mb_size_bar "$disk_pct" "$bar_w")
    printf "  ${C_DIM}Disk${C_NC}  %b  %s / %s  (%d%% used)\n\n" \
        "$disk_bar" \
        "$(mb_format_kb "$MB_DISK_USED_KB")" \
        "$(mb_format_kb "$MB_DISK_TOTAL_KB")" \
        "$disk_pct"

    local max_kb=1 i s
    for (( i=0; i<${#MB_MOD_SIZES_KB[@]}; i++ )); do
        s="${MB_MOD_SIZES_KB[$i]:-0}"
        (( s > max_kb )) && max_kb=$s
    done

    printf "  ${C_DIM}%-26s  %-${bar_w}s  %10s${C_NC}\n" "Category" "" "Size"

    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        local pct=0
        s="${MB_MOD_SIZES_KB[$i]:-0}"
        (( max_kb > 0 )) && pct=$(( s * 100 / max_kb ))
        local bar; bar=$(mb_size_bar "$pct" "$bar_w")
        printf "  %-26s  %b  %10s\n" \
            "${MB_MOD_LABELS[$i]}" "$bar" "$(mb_format_kb "$s")"
    done

    local total_kb=0
    for (( i=0; i<${#MB_MOD_SIZES_KB[@]}; i++ )); do
        total_kb=$(( total_kb + ${MB_MOD_SIZES_KB[$i]:-0} ))
    done
    printf "\n  ${C_DIM}Total scannable:${C_NC} ${C_BOLD}%s${C_NC}\n\n" "$(mb_format_kb "$total_kb")"
}

_cmd_list() {
    local mod="${1:-}"
    local use_json=false
    [[ "${2:-}" == "--json" || "${1:-}" == "--json" ]] && use_json=true

    if [[ -z "$mod" || "$mod" == "--json" ]]; then
        mb_error "Usage: macbroom list <module> [--json]"
        mb_dim   "Modules: ${MB_MOD_NAMES[*]}"
        exit 1
    fi

    # Validate module name
    local valid=false i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        if [[ "${MB_MOD_NAMES[$i]}" == "$mod" ]]; then valid=true; break; fi
    done
    if [[ "$valid" != "true" ]]; then
        mb_error "Unknown module: $mod"
        mb_dim   "Valid modules: ${MB_MOD_NAMES[*]}"
        exit 1
    fi

    if [[ "$use_json" == "true" ]]; then
        _json_list "$mod"
        return
    fi

    # Pretty list
    _run_scan  # need sizes for context
    local fn="" label="" idx=0
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        if [[ "${MB_MOD_NAMES[$i]}" == "$mod" ]]; then
            fn="${MB_MOD_LIST_FNS[$i]}"
            label="${MB_MOD_LABELS[$i]}"
            idx=$i
            break
        fi
    done

    printf "\n  ${C_BOLD}%s${C_NC}  ${C_DIM}(%s total)${C_NC}\n\n" \
        "$label" "$(mb_format_kb "${MB_MOD_SIZES_KB[$idx]:-0}")"

    local max_kb=1 line sk slabel
    local items=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && items+=("$line")
    done < <("$fn" 2>/dev/null)

    for line in "${items[@]}"; do
        sk="${line%%|*}"
        (( sk > max_kb )) && max_kb=$sk
    done

    local bar_w=16
    for line in "${items[@]}"; do
        sk="${line%%|*}"
        slabel="${line#*|}"
        local pct=0
        (( max_kb > 0 )) && pct=$(( sk * 100 / max_kb ))
        local bar; bar=$(mb_size_bar "$pct" "$bar_w")
        printf "  %-32s  %b  %10s\n" "$slabel" "$bar" "$(mb_format_kb "$sk")"
    done

    [[ ${#items[@]} -eq 0 ]] && mb_dim "  (nothing found)"
    printf "\n"
}

_cmd_clean() {
    local dry_run=false
    local mods_to_clean=()
    local clean_all=false

    # Parse args
    local a
    for a in "$@"; do
        case "$a" in
            --dry-run|-n) dry_run=true ;;
            --all|-a)     clean_all=true ;;
            -*)           mb_error "Unknown flag: $a"; exit 1 ;;
            *)            mods_to_clean+=("$a") ;;
        esac
    done

    _run_scan

    # Default: clean all if no specific modules given
    if [[ "$clean_all" == "false" ]] && [[ ${#mods_to_clean[@]} -eq 0 ]]; then
        clean_all=true
    fi

    local i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        MB_MOD_SELECTED[$i]=0
    done

    if [[ "$clean_all" == "true" ]]; then
        for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
            MB_MOD_SELECTED[$i]=1
        done
    else
        for m in "${mods_to_clean[@]+"${mods_to_clean[@]}"}"; do
            local found=false
            for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
                if [[ "${MB_MOD_NAMES[$i]}" == "$m" ]]; then
                    MB_MOD_SELECTED[$i]=1
                    found=true
                    break
                fi
            done
            if [[ "$found" != "true" ]]; then
                mb_error "Unknown module: $m"
                mb_dim   "Valid: ${MB_MOD_NAMES[*]}"
                exit 1
            fi
        done
    fi

    local any=0
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        if [[ "${MB_MOD_SELECTED[$i]:-0}" -eq 1 ]]; then any=1; break; fi
    done
    if [[ "$any" -eq 0 ]]; then mb_error "No modules selected."; exit 1; fi

    printf "\n"
    mb_bold "  MacBroom – Cleaning"
    [[ "$dry_run" == "true" ]] && printf "  ${C_YELLOW}(dry run – no files will be deleted)${C_NC}\n"
    printf "\n"

    local total_freed=0
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        [[ "${MB_MOD_SELECTED[$i]:-0}" -eq 1 ]] || continue
        local fn="${MB_MOD_CLEAN_FNS[$i]}"
        local label="${MB_MOD_LABELS[$i]}"
        printf "  ${C_BOLD}%s${C_NC}\n" "$label"
        local rfile; rfile=$(mktemp)
        "$fn" "$dry_run" "$rfile" 2>/dev/null || true
        local freed=0
        [[ -f "$rfile" ]] && freed=$(cat "$rfile")
        [[ "$freed" =~ ^[0-9]+$ ]] || freed=0
        rm -f "$rfile"
        total_freed=$(( total_freed + freed ))
        printf "\n"
    done

    if [[ "$dry_run" == "true" ]]; then
        mb_bold "  Dry run complete."
        mb_dim  "  Would free approximately $(mb_format_kb "$total_freed")"
    else
        mb_ok   "Total freed: $(mb_format_kb "$total_freed")"
    fi
    printf "\n"
}

_cmd_headless() {
    local safety_level="safe"
    local a
    for a in "$@"; do
        case "$a" in
            --safe)     safety_level="safe" ;;
            --moderate) safety_level="moderate" ;;
            --risky)    safety_level="risky" ;;
        esac
    done

    _run_scan

    local i
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        local safety="${MB_MOD_SAFETY[$i]:-safe}"
        case "$safety_level" in
            safe)     [[ "$safety" == "safe" ]] && MB_MOD_SELECTED[$i]=1 || MB_MOD_SELECTED[$i]=0 ;;
            moderate) [[ "$safety" == "safe" || "$safety" == "moderate" ]] && MB_MOD_SELECTED[$i]=1 || MB_MOD_SELECTED[$i]=0 ;;
            risky)    MB_MOD_SELECTED[$i]=1 ;;
        esac
    done

    local total_freed=0
    mb_undo_session_start
    for (( i=0; i<${#MB_MOD_NAMES[@]}; i++ )); do
        [[ "${MB_MOD_SELECTED[$i]:-0}" -eq 1 ]] || continue
        local fn="${MB_MOD_CLEAN_FNS[$i]}"
        export MB_CURRENT_MODULE="${MB_MOD_NAMES[$i]}"
        local rfile; rfile=$(mktemp)
        "$fn" "false" "$rfile" 2>/dev/null || true
        local freed=0
        [[ -f "$rfile" ]] && freed=$(cat "$rfile")
        [[ "$freed" =~ ^[0-9]+$ ]] || freed=0
        rm -f "$rfile"
        total_freed=$(( total_freed + freed ))
    done
    mb_undo_session_end
    mb_ok "Headless clean complete — $(mb_format_kb "$total_freed") freed"
}

