    ↑↓            Navigate
    Space         Toggle selection
    → / Enter     Open preview / Start cleaning
    A / N         Select all / Deselect all
    ← / Esc       Go back
    Q             Quit

  ${C_BOLD}Environment:${C_NC}
    MB_LOG_AGE_DAYS           Minimum log age (default: 7)
    MB_TEMP_AGE_DAYS          Minimum temp file age (default: 3)
    MB_APP_LEFTOVERS_QUERY    App name to search for leftover files

EOF
}

# ── Entry point ────────────────────────────────────────────────
main() {
    local cmd="${1:-}"

    case "$cmd" in
        scan)          shift; _cmd_scan "$@" ;;
        list)          shift; _cmd_list "$@" ;;
        clean)         shift; _cmd_clean "$@" ;;
        --dry-run|-n)
            MB_DRY_RUN=true
            _tui_main
            ;;
        --version|-v)  printf "MacBroom %s\n" "$MB_VERSION" ;;
        --help|-h)     _show_help ;;
        --install-cron)
            shift
            local days="${1:-7}" level="${2:-safe}"
            mb_cron_install "$days" "$level"
            ;;
        --remove-cron)
            mb_cron_remove
            ;;
        --cron-status)
            mb_cron_status
            ;;
        --log)
            shift
            local subcmd="${1:-last}"
            case "$subcmd" in
                last) mb_undo_last ;;
                list) mb_undo_list_sessions ;;
                *) mb_error "Usage: macbroom --log [last|list]" ;;
            esac
            ;;
        --headless)
            shift
            _cmd_headless "$@"
            ;;
        "")            _tui_main ;;
        *)
            mb_error "Unknown command: $cmd"
            _show_help
            exit 1
            ;;
    esac
}

main "$@"
